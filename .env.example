# ══════════════════════════════════════════════════════════════
# WHATSAPP AGENT - Environment Configuration (Template)
# Copie este arquivo para .env e preencha com seus valores reais
# Em produção (AWS): gerado automaticamente via SSM
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# BANCO DE DADOS (Supabase)
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.XXX:PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true
SUPABASE_URL=https://XXX.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ──────────────────────────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ──────────────────────────────────────────────────────────────
# API NODE (Backend)
# ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
JWT_SECRET=troque-por-uma-chave-secreta-forte-aqui
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
AI_SERVICE_URL=http://ai-service:8000
BAILEYS_SESSIONS_PATH=./sessions

# ──────────────────────────────────────────────────────────────
# AI SERVICE (Python/LLM)
# ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=

# ──────────────────────────────────────────────────────────────
# FRONTEND (Vite)
# ──────────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:3000
